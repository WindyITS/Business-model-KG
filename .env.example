# Local OpenAI-compatible endpoint defaults
LOCAL_LLM_API_KEY=lm-studio
LM_STUDIO_API_KEY=

# Published local query-stack bundle override
KG_QUERY_STACK_BUNDLE_DIR=

# Hosted OpenCode Go defaults
OPENCODE_GO_API_KEY=
OPENCODE_API_KEY=

# Optional prompt override
KG_PROMPTS_DIR=

# Docker Neo4j auth for docker-compose.yml
NEO4J_AUTH=neo4j/password
